# Django Core
DJANGO_ENV=local
SECRET_KEY=your-secret-key-here
DEBUG=True

# API Keys
GEMINI_KEY=your-gemini-api-key

# Azure Database (used when DJANGO_ENV=azure)
AZURE_DB_NAME=your-db-name
AZURE_DB_USER=your-db-user
AZURE_DB_PASSWORD=your-db-password
AZURE_DB_HOST=your-db-host.database.windows.net
AZURE_DB_PORT=1433

# Azure Storage
AZURE_ACCOUNT_NAME=your-storage-account-name
AZURE_ACCOUNT_KEY=your-storage-account-key
AZURE_CONTAINER=media
AZURE_URL_EXPIRATION_SECS=3600
